---
import Layout from '../../layouts/Layout.astro';
import DownloadPage from '../../components/DownloadPage';

// Import Assets
import pocketControllerLogo from '../../assets/products/pocketcontroller/logo/pocketcontroller.png';

const pcDownloadUrl = "https://github.com/zedlabs-corp/PocketController/releases/download/Setup/PocketController.Setup.1.0.0.exe";
---

<Layout>
  <DownloadPage 
    client:load
    title="PocketController"
    logoSrc={pocketControllerLogo.src}
    downloadLink={pcDownloadUrl}
    version="1.0.0"
    platform="Windows x64"
  />
</Layout>
